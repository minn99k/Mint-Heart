@page "/testhub"
@inject GameHubService gameHubService

<h3>SignalR Test</h3>

<div style="margin-bottom: 20px;">
    <button @onclick="Connect" disabled="@_connected">Connect</button>
    <p>Status: @_status</p>
</div>

<div style="margin-bottom: 20px; border: 1px solid #ccc; padding: 10px;">
    <h4>Test Join Room</h4>
    <input type="text" @bind="_roomId" placeholder="Room ID (e.g., 1234)" />
    <input type="text" @bind="_nickname" placeholder="Nickname" />
    <button @onclick="JoinRoom" disabled="@(!_connected)">Join Room</button>
</div>

<div style="border: 1px solid #ddd; padding: 10px; margin-top: 20px; min-height: 100px;">
    <h4>Messages:</h4>
    @foreach (var msg in _messages)
    {
        <p style="margin: 5px 0;">@msg</p>
    }
</div>

@code {
    private string _status = "Not Connected";
    private bool _connected = false;
    private string _roomId = "1234";
    private string _nickname = "TestPlayer";
    private List<string> _messages = new();

    private async Task Connect()
    {
        try
        {
            // Setup listeners BEFORE connecting
            gameHubService.OnPlayerJoined(nickname =>
            {
                _messages.Add($"✅ {nickname} joined!");
                StateHasChanged();
            });

            gameHubService.OnError(error =>
            {
                _messages.Add($"❌ Error: {error}");
                StateHasChanged();
            });

            gameHubService.OnPong(message =>
            {
                _messages.Add($"📍 Pong: {message}");
                StateHasChanged();
            });

            await gameHubService.StartAsync();
            _status = "Connected!";
            _connected = true;
            _messages.Add("Connected to server");
        }
        catch (Exception ex)
        {
            _status = $"Connection failed: {ex.Message}";
            _messages.Add($"💥 Connection error: {ex.Message}");
        }
    }

    private async Task JoinRoom()
    {
        try
        {
            _messages.Add($"📤 Sending JoinRoom('{_roomId}', '{_nickname}')...");
            await gameHubService.JoinRoomAsync(_roomId, _nickname);
        }
        catch (Exception ex)
        {
            _messages.Add($"💥 Join error: {ex.Message}");
        }
    }
}