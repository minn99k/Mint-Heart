@page "/waiting/{RoomId}"
@inject GameHubService Hub
@inject NavigationManager Nav
@implements IDisposable

<div class="waiting">
    <div class="room-code">
        <span class="label">방 코드</span>
        <span class="code">@RoomId</span>
        <span class="hint">친구에게 이 코드를 알려주세요</span>
    </div>

    <div class="players">
        <div class="player me">
            <span class="player-label">나</span>
            <span class="nickname">@Hub.MyNickname</span>
        </div>
        <div class="vs">VS</div>
        <div class="player opponent">
            <span class="player-label">상대</span>
            <span class="nickname @(Hub.OpponentNickname == "" ? "waiting-text" : "")">
                @(Hub.OpponentNickname == "" ? "대기 중..." : Hub.OpponentNickname)
            </span>
        </div>
    </div>

    @if (_countdown > 0)
    {
        <div class="countdown">@_countdown</div>
    }
    else if (_statusMessage != null)
    {
        <p class="status">@_statusMessage</p>
    }
    else
    {
        <p class="status">상대방 접속을 기다리는 중...</p>
    }

    <button class="back-btn" @onclick="GoToLobby">로비로 돌아가기</button>
</div>

<style>
    .waiting {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        gap: 32px;
        font-family: sans-serif;
    }
    .room-code {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
    }
    .room-code .label { font-size: 0.9rem; color: #888; }
    .room-code .code  { font-size: 3rem; font-weight: bold; letter-spacing: 8px; }
    .room-code .hint  { font-size: 0.85rem; color: #aaa; }
    .players {
        display: flex;
        align-items: center;
        gap: 32px;
    }
    .player {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        min-width: 120px;
    }
    .player-label { font-size: 0.8rem; color: #888; }
    .nickname      { font-size: 1.3rem; font-weight: bold; }
    .waiting-text  { color: #aaa; font-weight: normal; font-style: italic; }
    .vs            { font-size: 1.5rem; color: #ccc; font-weight: bold; }
    .countdown {
        font-size: 5rem;
        font-weight: bold;
        color: #4a90d9;
        animation: pulse 1s ease-in-out;
    }
    @@keyframes pulse {
        0%   { transform: scale(1.3); opacity: 0.5; }
        100% { transform: scale(1);   opacity: 1;   }
    }
    .status { color: #888; font-size: 0.95rem; }
    .back-btn {
        padding: 8px 20px;
        border: 1px solid #ccc;
        border-radius: 6px;
        background: white;
        color: #666;
        cursor: pointer;
        font-size: 0.9rem;
    }
    .back-btn:hover { background: #f5f5f5; }
</style>

@code {
    [Parameter] public string RoomId { get; set; } = "";

    private int     _countdown;
    private string? _statusMessage;
    private System.Threading.CancellationTokenSource? _countdownCts;

    protected override void OnInitialized()
    {
        Hub.OnPlayerJoined     += HandlePlayerJoined;
        Hub.OnCountdownStarted += HandleCountdownStarted;
        Hub.OnGameStarted      += HandleGameStarted;
        Hub.OnPlayerLeft       += HandlePlayerLeft;
    }

    private void HandlePlayerJoined(string nickname)
    {
        _statusMessage = null;
        StateHasChanged();
    }

    private void HandleCountdownStarted(int seconds)
    {
        _countdownCts?.Cancel();
        _countdownCts = new System.Threading.CancellationTokenSource();
        _ = RunCountdownAsync(seconds, _countdownCts.Token);
    }

    private async Task RunCountdownAsync(int seconds, System.Threading.CancellationToken ct)
    {
        for (var i = seconds; i > 0; i--)
        {
            if (ct.IsCancellationRequested) return;
            _countdown = i;
            await InvokeAsync(StateHasChanged);
            await Task.Delay(1000, ct).ContinueWith(_ => { }); // 취소 시 예외 무시
        }
    }

    private void HandleGameStarted(MintAndHeart.Shared.DTOs.GameStateDto dto, string myPlayerId)
    {
        Nav.NavigateTo("/game");
    }

    private void HandlePlayerLeft(string nickname)
    {
        _countdownCts?.Cancel();
        _countdown     = 0;
        _statusMessage = $"'{nickname}'이(가) 방을 나갔습니다.";
        StateHasChanged();
    }

    private void GoToLobby() => Nav.NavigateTo("/");

    public void Dispose()
    {
        _countdownCts?.Cancel();
        Hub.OnPlayerJoined     -= HandlePlayerJoined;
        Hub.OnCountdownStarted -= HandleCountdownStarted;
        Hub.OnGameStarted      -= HandleGameStarted;
        Hub.OnPlayerLeft       -= HandlePlayerLeft;
    }
}
